{
  "manifest_version": 3,
  "name": "MaxOpp aiSEO crawler",
  "version": "2.0.0",
  "description": "High-accuracy client-side link extraction and crawling tool for SEO audits.",
  "key": "",

  "icons": {
    "16": "./icon.png",
    "48": "./icon.png",
    "128": "./icon.png"
  },
  
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "nativeMessaging",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Dealership Crawler",
    "default_icon": {
      "16": "./icon.png",
      "48": "./icon.png",
      "128": "./icon.png"
    }
  }
}