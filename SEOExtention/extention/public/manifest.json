{
  "manifest_version": 3,
  "name": "MaxOpp aiSEO crawler",
  "version": "1.0.0",
  "description": "High-accuracy client-side link extraction and crawling tool for SEO audits.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open MAXOP"
  }
}